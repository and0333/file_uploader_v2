#!/bin/bash -e

# Если выполняется команда rails, то проверяем базу данных
if [ "${1}" = "./bin/thrust" ] || [ "${1}" = "./bin/rails" ]; then
  echo "Waiting for database..."

  # Ждём PostgreSQL (если используется)
  if [ -n "$DATABASE_HOST" ]; then
    until pg_isready -h $DATABASE_HOST -p ${DATABASE_PORT:-5432} -U ${DATABASE_USER:-postgres}; do
      echo "PostgreSQL is unavailable - sleeping"
      sleep 1
    done
    echo "PostgreSQL is up - continuing"
  fi

  # Подготавливаем базу данных без seeds в production
  echo "Preparing database..."
  ./bin/rails db:prepare

  echo "Database ready!"
fi

exec "${@}"
